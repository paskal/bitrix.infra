parameters:
    level: 5
    paths:
        - /web/prod/local
        - /web/prod/bitrix/php_interface/init.php
        - /web/prod/bitrix/php_interface/include
    excludePaths:
        analyseAndScan:
            - /web/prod/local/scripts/onetime (?)
            - /web/prod/local/modules/*/vendor (?)
            # 3rd-party Bitrix-injected modules under php_interface/include — not our code
            - /web/prod/bitrix/php_interface/include/esol.importxml
            - /web/prod/bitrix/php_interface/include/kda.importexcel
            - /web/prod/bitrix/php_interface/include/catalog_export
            - /web/prod/bitrix/php_interface/include/catalog_import
            - /web/prod/bitrix/php_interface/include/vsfr.merchant
            - /web/prod/bitrix/php_interface/include/sale_payment (?)
            # Legacy 800-line aspro-derived sitemap cron — too deeply nested for
            # PHPStan to reason about. Excluded everywhere now: diagnostic.neon
            # `includes: phpstan-owned.neon` so this excludePaths is inherited
            # (previous claim that it "stays in diagnostic scope" was true only
            # before the consolidation in phase 2).
            - /web/prod/local/cron/sitemap.regions.php
    scanDirectories:
        - /web/prod/bitrix/modules
        - /web/prod/bitrix/templates/aspro_max
        - /web/prod/local/modules
    reportUnmatchedIgnoredErrors: false
    tmpDir: /var/log/phpstan/tmp-owned
    ignoreErrors:
        # Bitrix component-template runtime injection: $APPLICATION, $arParams, $arResult, $this,
        # $templateFolder, $templateData, $componentPath, etc. are populated by the component
        # framework before the template file is included. PHPStan can't see the injection point,
        # so it reports thousands of "might not be defined". These are not real bugs.
        -
            message: '#^Variable \$(APPLICATION|USER|DB|arResult|arParams|arItem|arElement|arSection|templateName|templateFolder|templateFile|templateData|componentName|componentPath|component|this)\b.*might not be defined\.$#'
            paths:
                - /web/prod/local/templates/*
                - /web/prod/local/components/*
                - /web/prod/local/modules/*/options.php
                - /web/prod/local/modules/*/install/index.php
        # Cron-only narrower whitelist: cron files run as standalone scripts via Bitrix's
        # prolog_before.php bootstrap, which injects $APPLICATION, $USER, $DB, $CACHE_MANAGER
        # as globals. They do NOT receive component template scope ($arResult/$arParams/
        # $arItem/$templateData/$component/$this), so a "might not be defined" finding for
        # any of those names in a cron file IS a real bug — keep them surfacing.
        -
            message: '#^Variable \$(APPLICATION|USER|DB|CACHE_MANAGER)\b.*might not be defined\.$#'
            paths:
                - /web/prod/local/cron/*
        # Bitrix block-include files in local/templates/light/blocks/*: each block is dropped
        # into a host page that pre-defines $SECTIONS, $TITLE, $HIDE_TITLE, $SECTIONS_COUNT,
        # $host, $linkedArticles*, $linkedBanners*, $arTheme, $arRegion, $arTmpUser, etc. via
        # Aspro's IncludeFile() machinery. Standalone phpstan analysis can't see those.
        -
            message: '#^Variable \$\w+ might not be defined\.$#'
            paths:
                - /web/prod/local/templates/light/blocks/*
                - /web/prod/local/templates/light/header.php
                - /web/prod/local/templates/light/footer.php
                - /web/prod/local/templates/light/description.php
        # Bitrix custom component templates frequently use extract($arResult) at the top to
        # promote $arResult keys ($arSeoItem, $section, $sort, $arTheme, $arStoresFilter, etc.)
        # to local scope. Partial includes (e.g. _slider_partial.php) also pull in $key,
        # $arItem from the enclosing foreach scope of template.php. PHPStan can't trace either.
        # Scoped to the two component vendor-override trees we have (bitrix/ and aspro/) —
        # avoids silencing variable.undefined in any future component category we haven't
        # vetted as template-injection territory.
        -
            message: '#^Variable \$\w+ might not be defined\.$#'
            paths:
                - /web/prod/local/templates/light/components/bitrix/*
                - /web/prod/local/templates/light/components/aspro/*
        # B_PROLOG_INCLUDED guard at top of every Bitrix entry/component file: required
        # boilerplate; PHPStan sees the constant as 'true' and flags the !== true comparison
        # as always-false. Standard Bitrix pattern, do not touch.
        # Scoped to the trees where Bitrix entry/component/template files actually live —
        # a stray `true !== true` outside these paths should still surface.
        -
            message: '#^Strict comparison using !== between true and true will always evaluate to false\.$#'
            identifier: notIdentical.alwaysFalse
            paths:
                - /web/prod/local/templates/*
                - /web/prod/local/components/*
                - /web/prod/local/modules/*
                - /web/prod/local/cron/*
                - /web/prod/local/tools/*
                - /web/prod/bitrix/php_interface/*
        # Bitrix component templates compare extracted $arResult fields against literal
        # strings ('N'/'Y'/'CUSTOM'/...). PHPStan narrows the extracted type from the
        # default $arParams and concludes the comparison is constant — but at runtime
        # the values come from Bitrix admin/database. Not actionable in template files.
        -
            identifier: notIdentical.alwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: notEqual.alwaysFalse
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: identical.alwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: identical.alwaysFalse
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: if.alwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
                - /web/prod/local/templates/light/blocks/*
        -
            identifier: if.alwaysFalse
            paths:
                - /web/prod/local/templates/light/components/*
                - /web/prod/local/templates/light/blocks/*
        -
            identifier: booleanAnd.rightAlwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: booleanAnd.leftAlwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: booleanAnd.alwaysFalse
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: booleanAnd.alwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
                - /web/prod/local/templates/light/blocks/*
        -
            identifier: booleanOr.alwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: booleanOr.leftAlwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
                - /web/prod/local/templates/light/blocks/*
        -
            identifier: booleanOr.rightAlwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
                - /web/prod/local/templates/light/blocks/*
        -
            identifier: booleanNot.alwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: booleanNot.alwaysFalse
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: ternary.alwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: greater.alwaysTrue
            paths:
                - /web/prod/local/templates/light/components/*
        -
            identifier: deadCode.unreachable
            paths:
                - /web/prod/local/templates/light/components/*
        # ── Bitrix-API quirks: PHPStan sees the abstract base classes ─────────
        # PHPStan reports calls on Bitrix\Main\Data\Connection (abstract). At runtime
        # the factory returns MysqliConnection / MysqlConnection which has query(),
        # queryExecute(), queryScalar(), getSqlHelper(), getAffectedRowsCount(),
        # startTransaction(), commitTransaction(), rollbackTransaction(). The codebase
        # only ever uses the concrete subclass instance, so these calls are safe.
        -
            message: '#^Call to an undefined method Bitrix\\Main\\Data\\Connection::(query|queryExecute|queryScalar|getSqlHelper|getAffectedRowsCount|startTransaction|commitTransaction|rollbackTransaction)\(\)\.$#'
        # Similarly, Bitrix\Main\Request is abstract; Application::getInstance()->getContext()->getRequest()
        # returns Bitrix\Main\HttpRequest which adds isHttps(), getQuery(), getPost(),
        # getCookie(), getRequestUri(), getHttpHost(), getPostList(), isPost(). Safe.
        -
            message: '#^Call to an undefined method Bitrix\\Main\\Request::(isHttps|getQuery|getPost|getCookie|getRequestUri|getHttpHost|getPostList|isPost)\(\)\.$#'
        # Bitrix\Main\Response::addCookie() exists on the concrete HttpResponse subclass.
        -
            message: '#^Call to an undefined method Bitrix\\Main\\Response::addCookie\(\)\.$#'
        # Bitrix\Main\Data\Cache::getMemcache() exists on the Memcache backend subclass.
        -
            message: '#^Call to an undefined method Bitrix\\Main\\Data\\Cache::getMemcache\(\)\.$#'
        # Bitrix\Seo\Sitemap\Internals\RuntimeTable::update() — DataManager subclass at runtime.
        -
            message: '#^Call to an undefined static method Bitrix\\Seo\\Sitemap\\Internals\\RuntimeTable::update\(\)\.$#'
        # CBitrixComponent::applyTemplateModifications() — exists on CBitrixComponentTemplate
        # which is what `$this` actually is inside result_modifier.php template files.
        -
            message: '#^Call to an undefined method CBitrixComponent::applyTemplateModifications\(\)\.$#'
        # Bitrix runtime constants defined by prolog_before.php / aspro.max bootstrap.
        # SITE_ID is set by Bitrix on first request, POST_FORM_ACTION_URI by the form module.
        -
            message: '#^Constant (SITE_ID|POST_FORM_ACTION_URI) not found\.$#'
        # Bitrix\Main\Entity\* (ReferenceField, ExpressionField, Event) — declared in
        # bitrix/modules/main/lib/entity/*.php, but PHPStan's scanDirectories can't always
        # resolve them when they're used in HL-block colour handlers and menu cache queries.
        -
            message: '#^Instantiated class Bitrix\\Main\\Entity\\(ReferenceField|ExpressionField) not found\.$#'
        -
            message: '#^(Parameter \$\w+ of method \S+ has invalid type|Call to method \w+\(\) on an unknown class) Bitrix\\Main\\Entity\\Event\.$#'
        # Aspro\Max\Smartseo\General\Smartseo — Aspro module class loaded via autoload chain
        # that PHPStan misses when scanning standalone.
        -
            message: '#^Call to static method getCurrentData\(\) on an unknown class Aspro\\Max\\Smartseo\\General\\Smartseo\.$#'
        # ── Aspro pollutes global namespace ───────────────────────────────────
        # bitrix/modules/aspro.max/install/components/aspro/oneclickbuy.max/script.php:71
        # redeclares the built-in `json_encode($value)` with a single-arg signature.
        # PHPStan picks up the polluted stub and flags every legitimate 2-arg call as
        # "Function json_encode invoked with 2 parameters, 1 required." Can't fix the
        # vendor file; the calls are correct PHP.
        -
            message: '#^Function json_encode invoked with 2 parameters, 1 required\.$#'
        # ── checkToolAccess() ─────────────────────────────────────────────────
        # local/tools/*.php each include header.php before declaring checkToolAccess(),
        # which lives further down in the same file or in a shared include. PHPStan
        # processes them out of order. Harmless — file always runs top-to-bottom at runtime.
        -
            message: '#^Function checkToolAccess not found\.$#'
            paths:
                - /web/prod/local/tools/*
        # ── nullCoalesce / dead-code / narrowing false-positives in tools and components ──
        # calc/* components: defensive `BS_CATALOG_ID ?? 17` guards against bootstrap order
        # variations; constants module is included from multiple entrypoints.
        -
            identifier: nullCoalesce.expr
            paths:
                - /web/prod/local/components/calc/*
        -
            identifier: nullCoalesce.variable
            paths:
                - /web/prod/local/components/calc/*
        # ── calc HTMX server-side engines: defensive / phpstan-blind findings ──
        # The calc components (krovlya / fence / myagkaya-krovlya) are hand-written
        # server-side calculators; phpstan analyses a narrower world than runtime:
        #  • smaller.alwaysFalse — FenceCalc::calculate() fills count* through a dynamic
        #    `$this->{$type}($p, $result)` call whose target takes `array &$t` by
        #    reference. phpstan can't resolve a variable method, assumes the counts stay
        #    at their 0 init, and flags the LIVE `$result[$key] < 0` size-validation guard
        #    as always-false. The guard is real (negative posts/lags when too many
        #    gates/doors) — it must NOT be removed.
        #  • nullCoalesce.offset — FenceCalc is a standalone library class with its own
        #    validation; `$param['length'] ?? 0` is intentional defensiveness phpstan
        #    over-narrows from the single current caller's array shape.
        #  • function.alreadyNarrowedType / isset.offset — genuinely redundant defensive
        #    guards (is_array() on an always-array global, isset() on an always-present
        #    key). Harmless; same identifiers already ignored for templates/*. Fold these
        #    into source when the active calc rewrite WIP lands, then drop these two lines.
        #  • identical.alwaysTrue — *_test.php runners use a global $failures counter the
        #    check() helper increments; phpstan can't track it through the closure.
        -
            identifier: smaller.alwaysFalse
            paths:
                - /web/prod/local/components/calc/*
        -
            identifier: nullCoalesce.offset
            paths:
                - /web/prod/local/components/calc/*
        -
            identifier: function.alreadyNarrowedType
            paths:
                - /web/prod/local/components/calc/*
        -
            identifier: isset.offset
            paths:
                - /web/prod/local/components/calc/*
        -
            identifier: identical.alwaysTrue
            paths:
                - /web/prod/local/components/calc/*/lib/*_test.php
        # SEO tooling internal data shapes where defensive `?? 0`/`?? ''` is intentional
        # (functions return arrays that *should* always have the key, but the tool runs
        # against historical data with schema drift).
        -
            identifier: nullCoalesce.offset
            paths:
                - /web/prod/local/tools/*
                - /web/prod/local/modules/favorgroup.forms/options.php
        # ── function.alreadyNarrowedType, empty.variable, array.duplicateKey, etc. ──
        # Templates inherited from Aspro keep defensive `is_array($x)` after extract() and
        # duplicate array keys — both harmless artefacts of how the upstream template was
        # written before phpstan existed. Not worth touching Aspro-derived templates.
        -
            identifier: function.alreadyNarrowedType
            paths:
                - /web/prod/local/templates/*
                - /web/prod/bitrix/php_interface/include/CMaxLocal.php
        -
            identifier: empty.variable
            paths:
                - /web/prod/local/templates/*
                - /web/prod/bitrix/php_interface/include/CMaxLocal.php
        -
            identifier: array.duplicateKey
            paths:
                - /web/prod/local/templates/*
        # ── Tool-script offsets and shape narrowing ───────────────────────────
        # local/tools/catalog-meta.php, seo_duplicate_url_cleaner.php, seo_single_product_counter.php
        # have shapes phpstan over-narrows after array_merge — the runtime values come from
        # database iteration where the offset *may* be missing.
        -
            identifier: offsetAccess.notFound
            paths:
                - /web/prod/local/tools/*
                - /web/prod/local/modules/*/install/index.php
        -
            identifier: empty.offset
            paths:
                - /web/prod/local/tools/*
        -
            identifier: isset.offset
            paths:
                - /web/prod/local/templates/*
        -
            identifier: binaryOp.invalid
            paths:
                - /web/prod/local/tools/*
                - /web/prod/local/templates/*
        # ── regexp.pattern false positives ────────────────────────────────────
        # local/tools/rename.php builds the pattern array at runtime via prepare_replace()
        # which wraps each string in '/'…'/iu' delimiters. PHPStan validates the raw input
        # array (which contains literal product-category prefixes) as if it were the final
        # regex and reports 27 spurious findings.
        -
            identifier: regexp.pattern
            paths:
                - /web/prod/local/tools/rename.php
        # ── __MPF_ImageResizeHandler return-bool stub mismatch ────────────────
        # The local re-declaration in catalog.comments/blog/.../adapt/result_modifier.php
        # is signed `function __MPF_ImageResizeHandler(&$arCustomFile)` (no return type)
        # but the PHPStan stub coming from main/include/upload.php declares `:bool`.
        # The function returns void on the success path because Bitrix calls it as an
        # event handler that ignores the return value; matching Bitrix behaviour is
        # intentional. Scope the silencer to the single file that re-declares it.
        -
            message: '#^Function __MPF_ImageResizeHandler\(\) should return bool but return statement is missing\.$#'
            paths:
                - /web/prod/local/templates/light/components/bitrix/catalog.comments/blog/bitrix/blog.post.comment/adapt/result_modifier.php
        # ── ADMIN_SECTION constant comparisons ────────────────────────────────
        # ADMIN_SECTION is defined by Bitrix as the literal string 'Y' in admin
        # context, but the PHPStan stub declares it as `true`. The five files below
        # use defensive `defined('ADMIN_SECTION') && ADMIN_SECTION === true` or
        # `&& ADMIN_SECTION` (truthy) checks because the runtime value differs from
        # the stub in edge cases (custom admin handlers, cron CLI bootstrap).
        # PHPStan reports identical.alwaysTrue / booleanAnd.rightAlwaysTrue on each.
        # Scope tight: only these five call sites.
        -
            identifier: identical.alwaysTrue
            paths:
                - /web/prod/bitrix/php_interface/include/Favor.php
                - /web/prod/bitrix/php_interface/include/events.php
                - /web/prod/local/modules/favorgroup.sale/lib/EventHandlers.php
        -
            identifier: booleanAnd.rightAlwaysTrue
            paths:
                - /web/prod/local/modules/favorgroup.macros/lib/EventHandlers.php
                - /web/prod/local/modules/favorgroup.tracking/lib/EventHandlers.php
        # file_get_contents 3-arg form (filename, use_include_path, context) is valid PHP.
        # Likely Aspro polluted-stub issue again.
        -
            message: '#^Function file_get_contents invoked with 3 parameters, 1 required\.$#'
        # ── Class name case ─────────────────────────────────────────────────
        # Bitrix's CCatalogSku is callable as CCatalogSKU via Bitrix's case-insensitive
        # autoloader; the SKU spelling is what the original Aspro templates use everywhere.
        # PHP itself is case-insensitive for class names so this only fires under static
        # analysis. Fixing would touch ~10 Aspro-inherited templates without runtime benefit.
        # Scoped to the Aspro-inherited template tree only — a real misspelling outside
        # this tree (e.g. a fresh utility under local/tools/) should still surface.
        -
            identifier: class.nameCase
            paths:
                - /web/prod/local/templates/light/components/bitrix/*
        # ── new.noConstructor for Bitrix helper classes ───────────────────────
        # Bitrix\Main\Page\FrameHelper and Bitrix\Sale\ResultError both use __invoke-style
        # bootstrap rather than constructors, but the codebase consistently uses `new`
        # without args. Pattern in the original Aspro templates and the sale event-handler
        # bridge. Scoped to the three known call sites — a real no-ctor mistake elsewhere
        # should still surface.
        -
            identifier: new.noConstructor
            paths:
                - /web/prod/local/templates/light/components/bitrix/catalog/main/page_blocks/section.php
                - /web/prod/bitrix/php_interface/include/CMaxLocal.php
                - /web/prod/local/modules/favorgroup.sale/lib/EventHandlers.php
        # ── LeadService.php uses protected CAllFormCrm methods via Bitrix's permissive ─
        # legacy form API. These are documented entry points for custom lead-forwarding
        # despite the `protected` modifier on the parent.
        -
            message: '#^Call to protected static method (_getAllFormFields|_getAllFormFieldsHTML)\(\) of class CAllFormCrm\.$#'
            paths:
                - /web/prod/local/modules/favorgroup.forms/lib/LeadService.php
        # ── closure.unusedUse in pagination slider partial — leftover from refactor;
        # the use list is kept verbatim from the parent file to avoid drift if the
        # closure body grows back. Cosmetic, no runtime impact.
        -
            identifier: closure.unusedUse
            paths:
                - /web/prod/local/templates/light/components/bitrix/catalog.smart.filter/ajax/_slider_partial.php
        # ── nullsafe on Bitrix\Sale\EntityPropertyValue — PHPStan sees the return as
        # non-nullable; defensive `?->` pattern is kept because the Sale module's
        # getPropertyCollection() can return Throwable shapes when an order is malformed.
        -
            identifier: nullsafe.neverNull
            paths:
                - /web/prod/local/modules/favorgroup.sale/lib/EventHandlers.php
        # ── seo_text_sanitiser ContentAnalyzer calls validateContent() on an interface
        # that's implemented by 3 sources but the interface signature lists only
        # getMatchingRecords(). Real ContentSource subclasses each have validateContent();
        # the interface needs broadening but the change is out of scope here.
        -
            message: '#^Call to an undefined method SeoTextSanitiser\\ContentSourceInterface::validateContent\(\)\.$#'
        # ── whitespace.fileEnd in legacy element_1.php template — cosmetic;
        # the closing ?> + newline is the historical Bitrix pattern. Scoped to the
        # Aspro-inherited template tree — real trailing-whitespace mistakes elsewhere
        # (utilities, modules) still surface.
        -
            identifier: whitespace.fileEnd
            paths:
                - /web/prod/local/templates/light/components/bitrix/*
        # ── require.fileNotFound in flush_mc.php uses a runtime path through
        # /web/bitrix/ symlink chain that PHPStan can't resolve from its sandbox.
        # The file definitely exists at runtime (script is used daily for cache flush).
        -
            message: '#^Path in require\(\) "/web/bitrix/modules/main/include/prolog_before\.php" is not a file or it does not exist\.$#'
        # ── property.onlyWritten in SeoTextClusterAnalyzer is a real follow-up
        # ($webRoot is captured by constructor for future use); not worth a refactor
        # right now, accept as tracked residual.
        -
            identifier: property.onlyWritten
            paths:
                - /web/prod/local/tools/seo_text_cluster_analyzer/*
