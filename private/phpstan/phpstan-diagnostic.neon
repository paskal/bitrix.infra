includes:
    # Inherit all parameters + ignoreErrors from the owned scope.
    # Diagnostic intentionally re-uses owned's silencers so vendor/template
    # noise stays quiet — diagnostic exists to surface NEW classes of issues
    # under the broader scope (bitrix/templates/aspro_max), not to re-litigate
    # the 30+ rules we already classified as not-actionable in owned.
    # To temporarily un-silence everything for a one-off audit, comment out
    # the include or override with `parameters.ignoreErrors: []` below.
    - phpstan-owned.neon
parameters:
    paths:
        - /web/prod/local
        - /web/prod/bitrix/php_interface
        - /web/prod/bitrix/templates/aspro_max
    tmpDir: /var/log/phpstan/tmp-diagnostic
