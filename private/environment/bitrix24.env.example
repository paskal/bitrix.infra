# Bitrix24 REST webhook (inbound webhook on user account — replace USER_ID / WEBHOOK_TOKEN)
# Used by: agent scripts hitting crm.deal.list, crm.lead.list, tasks.task.* etc.
B24_WEBHOOK_URL=https://fs-group.bitrix24.ru/rest/USER_ID/WEBHOOK_TOKEN

# Bitrix admin panel login
# Used by: bitrix-cache-clear skill (agent-browser sessions for ?clear_cache=Y)
BITRIX_ADMIN_USER=admin@example.com
BITRIX_ADMIN_PASSWORD=changeme
