# Percona MySQL credentials
# https://hub.docker.com/r/percona/percona-server

# root password for the MySQL server
MYSQL_ROOT_PASSWORD=change_me

# application database user (used by PHP for Bitrix)
MYSQL_USER=bitrix_user
MYSQL_PASSWORD=change_me

# read-only user for AI agents (Claude Code via bin/fgmysql)
# create with: GRANT SELECT ON favor_group_ru.* TO 'claude_ro'@'localhost';
MYSQL_CLAUDE_RO_PASSWORD=change_me
