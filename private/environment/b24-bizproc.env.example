# Bitrix24 OAuth «ClaudeAdmin» local app — scopes crm + bizproc
# Used by: b24-bizproc-edit skill (OAuth dance to unlock template add/delete beyond what the REST webhook allows)
# Register the app at https://fs-group.bitrix24.ru/devops/edit/standard/ → «Локальное приложение»; copy app code (CLIENT_ID) + secret (CLIENT_SECRET).
B24_BIZPROC_CLIENT_ID=local.xxxxxxxxxxxxxxx.xxxxxxxx
B24_BIZPROC_CLIENT_SECRET=replace_with_oauth_app_secret

# Bitrix24 admin browser login — account managing fs-group.bitrix24.ru
# Used by: b24-bizproc-edit skill (agent-browser sessions to drive the BP designer UI when REST is insufficient)
B24_BIZPROC_USER=admin@example.com
B24_BIZPROC_PASS=changeme
