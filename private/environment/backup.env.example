# S3 backup configuration for scripts/file-backup.sh, scripts/mysql-dump.sh,
# and scripts/compare-backups.sh.
# Copy to backup.env and fill in your values.

# S3 bucket name (without s3:// prefix)
BACKUP_S3_BUCKET=my-backup-bucket

# S3 endpoint URL (leave empty for AWS; set for compatible providers)
S3_ENDPOINT_URL=https://storage.example.com

# Domain name — used to derive the MySQL database name for dumps.
# Must match the MYSQL_DATABASE value in mysql.env (dots and hyphens → underscores).
DOMAIN=example.com
