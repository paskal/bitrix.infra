# Yandex Webmaster credentials for the daily recrawl batch worker (scripts/seo-reindex.sh).
# OAuth token must have webmaster:hostinfo scope (covers the recrawl/quota and recrawl/queue endpoints).
# user_id is the numeric Yandex user ID (NOT a login). Get it once via:
#   curl -s -H "Authorization: OAuth $TOKEN" https://api.webmaster.yandex.net/v4/user/

YANDEX_WEBMASTER_TOKEN=
YANDEX_WEBMASTER_USER_ID=
