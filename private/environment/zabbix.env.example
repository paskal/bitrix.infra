# Zabbix Agent 2 configuration
# https://hub.docker.com/r/zabbix/zabbix-agent2

# timezone for the agent (should match the server timezone)
TZ=UTC

# hostname as registered in the Zabbix server
ZBX_HOSTNAME=myhostname

# address of the Zabbix server
ZBX_SERVER_HOST=zabbix.example.com

# restrict which monitoring keys the agent can execute
# https://www.zabbix.com/documentation/current/en/manual/config/items/restrict_checks
ZBX_DENYKEY=system.run[*]
ZBX_ALLOWKEY=docker.*,vfs.*,system.*,net.*,proc.*,agent.*,web.*,mysql.*

# MySQL setup for database monitoring:
#   CREATE USER 'zbx_monitor'@'localhost' IDENTIFIED BY 'random_password';
#   GRANT PROCESS, REPLICATION CLIENT, SHOW DATABASES, SHOW VIEW ON *.* TO 'zbx_monitor'@'localhost';
