# Yandex Cloud DNS credentials for DNSroboCert (Let's Encrypt wildcard certs)
# https://github.com/adferrand/dnsrobocert

# short-lived IAM token, auto-refreshed by scripts/update-dns-token.sh
# initial token: run `yc iam create-token` after `yc components update`
AUTH_KEY=insert_token_here

# DNS zone ID from https://console.cloud.yandex.com/link/dns
DNS_ZONE_ID=insert_zone_id_here

# alternative to DNS_ZONE_ID: provide cloud and folder IDs instead
# the zone is looked up automatically within the folder
# CLOUD_ID=insert_cloud_id_here
# FOLDER_ID=insert_folder_id_here
